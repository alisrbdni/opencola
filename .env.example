# Copy this to .env and fill in your keys
# Note: For a Chrome extension, API keys should be stored in chrome.storage.sync
#       via the options page, NOT in the bundle. This file is for local development only.

# Optional: Pre-seed for development builds only
DEV_OPENAI_KEY=sk-...
DEV_ANTHROPIC_KEY=sk-ant-...
DEV_GEMINI_KEY=...
DEV_GROQ_KEY=gsk_...
